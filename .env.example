# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Interactive Brokers (IB Gateway / TWS) ---
IB_HOST=host.docker.internal
IB_PORT=4002          # 4002 = IB Gateway paper, 7497 = TWS paper
IB_CLIENT_ID=1
IB_ACCOUNT=DU0000000  # paper account id

# --- Trading mode: mock | paper | live ---
TRADING_MODE=mock

# --- Risk limits ---
RISK_MAX_POSITION_USD=10000
RISK_MAX_DAILY_LOSS_USD=2000
RISK_MAX_ORDER_QTY=500
